################################################################
# Required to run the bot
################################################################

# Telegram
OWNER_CHAT_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# LLM provider (DeepSeek by default; any OpenAI-compatible endpoint works)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-chat
LLM_EMBED_MODEL=deepseek-embed
LLM_EMBED_DIMENSIONS=1536

# Supabase project
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

################################################################
# Required if you want the web calendar deployed for you
################################################################

# Token from https://dash.cloudflare.com/profile/api-tokens
# (use the "Edit Cloudflare Workers" template)
CLOUDFLARE_API_TOKEN=
# Find it on the right sidebar of your Cloudflare dashboard.
CLOUDFLARE_ACCOUNT_ID=
# Optional: pin a project name. Defaults to a random "cal-XXXX" slug.
CLOUDFLARE_PAGES_PROJECT=

################################################################
# Optional features (set only the ones you want)
################################################################

# Public URL of the calendar Edge Function. Filled by the installer
# automatically once the calendar is deployed.
CALENDAR_BASE_URL=

# Email backup for reminders (Resend)
RESEND_API_KEY=
OWNER_EMAIL=

# Weather: openweathermap.org, free
OPENWEATHER_API_KEY=

# News headlines (one is enough; gnews preferred)
GNEWS_API_KEY=
NEWSAPI_API_KEY=

# Web search (one is enough; tavily preferred)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
